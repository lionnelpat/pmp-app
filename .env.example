# ── Secrets de production ──
# Dokploy : coller ces variables dans l'onglet « Environment » du service.
# (En dehors de Dokploy : cp .env.example .env)

# Base de données
POSTGRES_DB=pmp_quiz
POSTGRES_USER=pmp_user
POSTGRES_PASSWORD=change_moi_mot_de_passe_fort

# Authentification (générer : openssl rand -hex 32)
JWT_SECRET=change_moi_secret_jwt_64_caracteres
JWT_EXPIRES_IN=7d

# Compte administrateur créé automatiquement au 1er démarrage
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ChangeMoiAdmin2024!
ADMIN_EMAIL=admin@ton-domaine.com

# Le domaine public et le HTTPS sont configurés dans l'UI Dokploy
# (onglet Domains → service "frontend", port 80), pas ici.
